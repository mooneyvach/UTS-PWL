<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="bg-white p-6 rounded-2xl shadow">
    <p class="text-gray-500">Total Mahasiswa</p>
    <p class="text-3xl font-bold text-blue-600"><%= mahasiswa.length %></p>
  </div>
  <div class="bg-white p-6 rounded-2xl shadow">
    <p class="text-gray-500">Total Dosen</p>
    <p class="text-3xl font-bold text-green-600">35</p>
  </div>
  <div class="bg-white p-6 rounded-2xl shadow">
    <p class="text-gray-500">Total Matkul</p>
    <p class="text-3xl font-bold text-purple-600">50</p>
  </div>
</div>
<div class="bg-white p-6 rounded-2xl shadow">
  <h2 class="text-xl font-bold mb-4">Data Mahasiswa</h2>
  <table class="w-full table-auto">
    <thead class="bg-blue-600 text-white">
      <tr>
        <th class="p-2">No</th>
        <th class="p-2">Nama</th>
        <th class="p-2">NIM</th>
      </tr>
    </thead>
    <tbody>
      <% mahasiswa.forEach((m, i) => { %>
      <tr class="border-b">
        <td class="p-2 text-center"><%= i + 1 %></td>
        <td class="p-2 text-center"><%= m.nama %></td>
        <td class="p-2 text-center"><%= m.nim %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>